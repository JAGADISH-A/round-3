# ═══════════════════════════════════════════════════════════════════════════════
# BumbleBee AI — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Environment & Secrets (CRITICAL) ─────────────────────────────────────────
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# ─── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.swp
*.swo
*.bak
*.tmp
*.log

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/
.factorypath
.history/
*.launch

# ─── AI Agent Config (local dev tooling — not part of app source) ─────────────
.agent/
.gemini/

# ─── Node.js / Next.js  (frontend/) ──────────────────────────────────────────
node_modules/
**/node_modules/
.next/
**/.next/
out/
build/
dist/
.turbo/
.vercel/
tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Python  (ai-service/) ───────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
*.cover
.venv/
**/venv/
venv/
env/
virtualenv/
*.egg-info/
*.egg
.installed.cfg
.Python
pip-log.txt
pip-delete-this-directory.txt

# ChromaDB / vector stores
chroma_db/
**/chroma_db/

# Datasets (large files — keep only README/schema)
dataset/
**/dataset/
careerspark_data_external/

# ─── Java / Maven  (backend/) ────────────────────────────────────────────────
target/
**/target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# ─── Audio / Media (generated at runtime) ────────────────────────────────────
*.wav
*.mp3
*.ogg
*.flac

# ─── Temp / Scratch Files ────────────────────────────────────────────────────
tmp/
**/tmp/
temp_*/
verify_output.txt
verify_*.py
test_*.wav
trace_imports.py
test_normalization.py
pip_list*.txt
tmp_strings.txt
.ipynb_checkpoints/

# ─── Compiled / Generated ────────────────────────────────────────────────────
*.pyc
*.pyo
*.pyd
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
