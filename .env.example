# BumbleBee AI - Global Environment Configuration Example
# Copy this file to .env and fill in the required values.

# ─── PRIMARY PORT CONFIG ──────────────────────────────────────────────────────
# Gateway Port
SERVER_PORT=8080

# Intelligence Service Port
INTELLIGENCE_PORT=8001

# Vision Service Port
VISION_PORT=8002

# Frontend Port
FRONTEND_PORT=3002

# ─── TELEGRAM BOT CONFIG ──────────────────────────────────────────────────────
# Obtain this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── AI API KEYS ─────────────────────────────────────────────────────────────
# Required for LangChain & Intelligence Service
GROQ_API_KEY=your_groq_api_key_here

# Required for Google Gemini API (if used)
GOOGLE_API_KEY=your_google_api_key_here

# Required for VAPI Voice AI
NEXT_PUBLIC_VAPI_API_KEY=your_vapi_api_key_here
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# Required for HuggingFace (if used)
HF_TOKEN=your_huggingface_token_here

# ─── FIREBASE CONFIGURATION (Frontend) ────────────────────────────────────────
# Required for user authentication and data persistence
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ─── SERVICE ENDPOINTS (Frontend) ─────────────────────────────────────────────
# Use these URLs for the frontend to communicate with backend services
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_VISION_URL=http://localhost:8002
