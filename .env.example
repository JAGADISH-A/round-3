# --- BumbleBee AI - Unified Environment Configuration ---
# 
# This file contains placeholders for all environment variables required across 
# the BumbleBee AI ecosystem. Copy this to .env (root) or relevant service folders.

# ─── FRONTEND (Next.js) ───────────────────────────────────────────────────────
# API Endpoints
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_VISION_URL=http://localhost:8002

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ─── AI SERVICES (Python FastAPI) ──────────────────────────────────────────
# LLM Providers
GROQ_API_KEY=your_groq_api_key
GOOGLE_API_KEY=your_google_gemini_api_key

# Telegram Integration (Optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ─── BACKEND GATEWAY (Java Spring Boot) ───────────────────────────────────────
# (Add specific gateway variables here if needed)
SERVER_PORT=8080
